# ============================================================
# PaperBot environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Binance Futures Testnet ---
# Get keys from: https://testnet.binancefuture.com/
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
BINANCE_TESTNET=true          # set false only for mainnet paper trading

# --- Telegram ---
# 1. Create a bot via @BotFather and copy the token below.
# 2. Start a chat with your bot then call:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat_id.
TELEGRAM_BOT_TOKEN=123456:ABCdef...
TELEGRAM_CHAT_ID=987654321

# --- Capital ---
INITIAL_CAPITAL=10000         # USD, paper only
LEVERAGE=3
MAX_CONCURRENT_PAIRS=5
MAX_POSITION_PCT=0.20         # fraction of equity per pair (before leverage)

# --- Risk ---
MAX_PORTFOLIO_DD=0.25         # kill switch at 25% portfolio draw-down
STOP_LOSS_PCT=0.15            # 15% per-trade stop loss
MAX_DATA_STALENESS_MIN=90     # kill switch if data older than 90 min

# --- Signal ---
Z_ENTRY=1.5
Z_EXIT=0.0
ROLLING_WINDOW=4320           # hours (≈ 6 months)
FEE_BPS=4.5                   # Binance VIP-0 + BNB discount
TIMEFRAME=1h

# --- Pair selection ---
CORR_LOG_PRICE_MIN=0.90
CORR_RETURN_MIN=0.50
COINT_PVALUE_MAX=0.05
IC_THRESHOLD=-0.10            # z-score IC must be ≤ this (negative = mean-reverting)
TOP_N_PAIRS=5

# --- Token universe (comma-separated, no spaces) ---
CANDIDATE_TOKENS=BTC,ETH,SOL,ADA,AVAX,DOT,BAND,NKN,ANKR,ONT,CTSI,STORJ,ENJ,ZRX,ATA,DOGE,MATIC,LINK,UNI,ATOM

# --- Data ---
WARMUP_HOURS=4320
